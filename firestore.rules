rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity validations with optional key safeguards using 'in' operator
    function isValidUserProfile(data) {
      return data.fullName is string && data.fullName.size() <= 150
        && data.email is string && data.email.size() <= 150
        && (!('phone' in data) || data.phone is string)
        && data.businessName is string && data.businessName.size() <= 150
        && (!('category' in data) || data.category is string)
        && (!('address' in data) || data.address is string)
        && (!('currency' in data) || data.currency is string)
        && (!('whatsappGreeting' in data) || data.whatsappGreeting is string)
        && (!('whatsappReminderSuffix' in data) || data.whatsappReminderSuffix is string);
    }

    function isValidProduct(data) {
      return data.userId is string && data.userId == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 150
        && (!('sku' in data) || data.sku is string)
        && data.stockLevel is int
        && data.buyingPrice is number
        && data.sellingPrice is number
        && (!('category' in data) || data.category is string);
    }

    function isValidSale(data) {
      return data.userId is string && data.userId == request.auth.uid
        && data.productId is string && data.productId.size() > 0
        && data.productName is string && data.productName.size() > 0
        && data.quantity is int && data.quantity >= 0
        && data.totalAmount is number
        && data.amountPaid is number
        && data.balanceDebt is number
        && data.customerName is string && data.customerName.size() <= 150
        && (!('customerPhone' in data) || data.customerPhone is string)
        && (!('paymentStatus' in data) || data.paymentStatus is string);
    }

    function isValidBankAccount(data) {
      return data.userId is string && data.userId == request.auth.uid
        && data.bankName is string && data.bankName.size() > 0 && data.bankName.size() <= 150
        && data.accountNumber is string && data.accountNumber.size() > 0 && data.accountNumber.size() <= 50
        && data.accountName is string && data.accountName.size() > 0 && data.accountName.size() <= 150
        && data.isDefault is bool;
    }

    function isValidDirectPaymentRecord(data) {
      return data.userId is string && data.userId == request.auth.uid
        && data.customerName is string && data.customerName.size() > 0
        && data.amount is number
        && data.receivingBank is string && data.receivingBank.size() > 0;
    }

    // Matches
    match /users/{userId} {
      allow get, write: if isOwner(userId) && (request.method == 'delete' || isValidUserProfile(request.resource.data));
    }

    match /products/{productId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidProduct(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid && isValidProduct(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /sales/{saleId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidSale(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid && isValidSale(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /bankAccounts/{accountId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidBankAccount(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid && isValidBankAccount(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /paymentRecords/{recordId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidDirectPaymentRecord(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid && isValidDirectPaymentRecord(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
