# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional alternative API for LLM fallbacks (e.g., OpenRouter)
OPENROUTER_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# Appwrite Configurations
VITE_APPWRITE_ENDPOINT="https://cloud.appwrite.io/v1"
VITE_APPWRITE_PROJECT_ID=""
VITE_APPWRITE_DATABASE_ID="sabisell_db"
VITE_APPWRITE_USERS_COLLECTION_ID="users"
VITE_APPWRITE_PRODUCTS_COLLECTION_ID="products"
VITE_APPWRITE_SALES_COLLECTION_ID="sales"
